# ─── Emporia Vue credentials (REQUIRED) ─────────────────────────────────────
# These are the same email/password you use to log in to the Emporia mobile app.
EMPORIA_EMAIL=you@example.com
EMPORIA_PASSWORD=your-emporia-password

# ─── Server ─────────────────────────────────────────────────────────────────
# HTTP port (default: 3030)
PORT=3030
# Bind address (default: 0.0.0.0 — all interfaces)
HOST=0.0.0.0

# ─── Storage ─────────────────────────────────────────────────────────────────
# Where to store cached auth tokens. Defaults to ~/.local/share/emporia-monitor/
# DATA_DIR=/var/lib/emporia-monitor

# ─── Plugin selection ───────────────────────────────────────────────────────
# Which energy data source to use. Currently only "emporia" is supported, but
# the architecture is plugin-based for future backends (Sense, Iotawatt, Shelly EM).
PLUGIN=emporia

# ─── Emporia plugin (optional overrides) ────────────────────────────────────
# If you have multiple Emporia devices on one account, pick which one (default 0).
# EMPORIA_DEVICE_INDEX=0
# Override the device's reported timezone (default: use what Emporia returns).
# EMPORIA_TIMEZONE=America/Chicago
# Custom path to the cached auth tokens file.
# EMPORIA_KEYS_FILE=/path/to/emporia_keys.json

# ─── Optional: Raspberry Pi deployment (used by deploy/deploy.sh) ───────────
# Set DEPLOY_ENABLED=1 to use the deploy script. Otherwise, run locally.
# DEPLOY_ENABLED=1
# DEPLOY_HOST=pi@raspberrypi.local
# DEPLOY_PASSWORD=                # optional; otherwise uses SSH key auth
# DEPLOY_DIR=/home/pi/emporia-monitor
# DEPLOY_NODE_VERSION=20.18.1     # bundled, never installed system-wide
